version: '3.8'

services:
  postgres:
    image: postgres:16-alpine
    secrets:
      - postgres_password
    environment:
      POSTGRES_USER: n8n
      POSTGRES_DB: n8n
      POSTGRES_PASSWORD_FILE: /run/secrets/postgres_password
    volumes:
      - pg_data:/var/lib/postgresql/data
    networks:
      - n8n-net
    deploy:
      placement:
        constraints: [node.role == manager]
      resources:
        limits:
          cpus: '1.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 1G

  redis:
    image: redis:7-alpine
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    networks:
      - n8n-net
    deploy:
      placement:
        constraints: [node.role == manager]

  n8n-main:
    image: n8nio/n8n:2.18.4
    depends_on:
      - postgres
      - redis
    secrets:
      - postgres_password
      - n8n_user
      - n8n_password
      - n8n_encryption_key
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD_FILE: /run/secrets/postgres_password
      QUEUE_BULL_REDIS_HOST: redis
      EXECUTIONS_MODE: queue
      N8N_ENCRYPTION_KEY_FILE: /run/secrets/n8n_encryption_key
      N8N_BASIC_AUTH_ACTIVE: "true"
      N8N_BASIC_AUTH_USER_FILE: /run/secrets/n8n_user
      N8N_BASIC_AUTH_PASSWORD_FILE: /run/secrets/n8n_password
      WEBHOOK_URL: https://n8n.expert-only.ru  # ← replace
    volumes:
      - n8n_data:/home/node/.n8n
    networks:
      - traefik-public
      - n8n-net
    deploy:
      replicas: 1
      placement:
        constraints: [node.role == manager]
      resources:
        limits:
          cpus: '1.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 1G
      labels:
        - "traefik.docker.network=traefik-public"
        - "traefik.enable=true"
        - "traefik.http.routers.n8n.rule=Host(`n8n.expert-only.ru`)" # ← replace
        - "traefik.http.routers.n8n.entrypoints=websecure"
        - "traefik.http.routers.n8n.tls.certresolver=letsencrypt"
        - "traefik.http.services.n8n.loadbalancer.server.port=5678"

  n8n-worker:
    image: n8nio/n8n:2.18.4
    command: worker
    depends_on:
      - postgres
      - redis
      - n8n-main
    secrets:
      - postgres_password
      - n8n_encryption_key
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD_FILE: /run/secrets/postgres_password
      QUEUE_BULL_REDIS_HOST: redis
      EXECUTIONS_MODE: queue
      N8N_ENCRYPTION_KEY_FILE: /run/secrets/n8n_encryption_key
    networks:
      - n8n-net
      - traefik-public
    deploy:
      replicas: 2
      resources:
        limits:
          cpus: '2.0'
          memory: 4G
        reservations:
          cpus: '1.0'
          memory: 2G
networks:
  n8n-net:
    external: true
  traefik-public:
    external: true

volumes:
  pg_data:
  redis_data:
  n8n_data:

secrets:
  postgres_password:
    external: true
  n8n_user:
    external: true
  n8n_password:
    external: true
  n8n_encryption_key:
    external: true
